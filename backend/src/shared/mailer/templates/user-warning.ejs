<%- include('_header') %>
<h1 style="font-size: 26px; font-weight: 600; color: #c0392b; margin: 0 0 25px 0; line-height: 1.3;">Account Warning Notice</h1>

<p style="font-size: 16px; color: #666; margin: 0 0 25px 0; line-height: 1.6;">
  Dear <strong style="color: #2C5270;"><%= name %></strong>,
</p>

<p style="font-size: 15px; color: #333; line-height: 1.8; margin: 0 0 20px 0;">
  We are writing to inform you that our Trust & Safety team has reviewed your account activity and identified behaviour that may violate our <strong>Community Guidelines</strong> and <strong>Terms of Service</strong>.
</p>

<!-- Warning Box -->
<div style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%); border-left: 4px solid #f39c12; border-radius: 8px; padding: 20px 25px; margin: 25px 0;">
  <p style="font-size: 14px; font-weight: 700; color: #856404; margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 0.5px;">⚠ Reason for Warning</p>
  <p style="font-size: 15px; color: #533f03; margin: 0; line-height: 1.7;"><%= reason %></p>
  <% if (adminNotes) { %>
  <p style="font-size: 14px; color: #6d4c00; margin: 12px 0 0 0; padding-top: 12px; border-top: 1px solid #f0c040; line-height: 1.6;"><strong>Additional notes:</strong> <%= adminNotes %></p>
  <% } %>
</div>

<!-- What This Means -->
<div style="background: #f8f9fa; border-radius: 10px; padding: 22px 25px; margin: 25px 0;">
  <h3 style="color: #2C5270; font-size: 16px; font-weight: 600; margin: 0 0 12px 0;">What this means for your account:</h3>
  <ul style="color: #555; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 20px;">
    <li style="margin-bottom: 8px;">This is an <strong>official warning</strong> — no immediate action has been taken.</li>
    <li style="margin-bottom: 8px;">Continued violations may result in <strong>account suspension or permanent removal</strong>.</li>
    <li style="margin-bottom: 8px;">Any reviews that violate our guidelines may be removed without notice.</li>
    <li style="margin-bottom: 8px;">Your reputation score may be affected by ongoing violations.</li>
  </ul>
</div>

<!-- What To Do -->
<div style="background: linear-gradient(135deg, #e8f5e8 0%, #d4edda 100%); border-left: 4px solid #28a745; border-radius: 8px; padding: 20px 25px; margin: 25px 0;">
  <h3 style="color: #155724; font-size: 16px; font-weight: 600; margin: 0 0 12px 0;">What you should do:</h3>
  <ol style="color: #1e4d2b; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 20px;">
    <li style="margin-bottom: 8px;">Review our <a href="<%= appUrl %>/terms" style="color: #28a745; text-decoration: none; font-weight: 600;">Terms of Service</a> and <a href="<%= appUrl %>/guidelines" style="color: #28a745; text-decoration: none; font-weight: 600;">Community Guidelines</a>.</li>
    <li style="margin-bottom: 8px;">Ensure all future reviews are genuine, honest, and based on real experiences.</li>
    <li style="margin-bottom: 8px;">Only submit reviews for businesses you have actually visited or transacted with.</li>
    <li style="margin-bottom: 8px;">If you believe this warning is in error, please contact our support team.</li>
  </ol>
</div>

<!-- CTA -->
<div style="text-align: center; margin: 30px 0;">
  <a href="<%= appUrl %>/dashboard"
     style="display: inline-block; background: linear-gradient(135deg, #2C5270 0%, #3A6B8A 100%); color: #ffffff; text-decoration: none; padding: 13px 30px; border-radius: 8px; font-weight: 600; font-size: 15px; box-shadow: 0 4px 12px rgba(44, 82, 112, 0.3); margin-right: 12px;">
    Go to My Account →
  </a>
  <a href="mailto:support@crediscore.com"
     style="display: inline-block; background: #f8f9fa; color: #2C5270; text-decoration: none; padding: 13px 30px; border-radius: 8px; font-weight: 500; font-size: 15px; border: 1px solid #dee2e6;">
    Contact Support
  </a>
</div>

<p style="font-size: 14px; color: #666; line-height: 1.8; margin: 25px 0 0 0; padding-top: 20px; border-top: 1px solid #e9ecef;">
  We value every member of the CrediScore community and want to ensure a fair, trustworthy platform for everyone. We appreciate your cooperation in maintaining the integrity of our platform.
</p>

<p style="font-size: 15px; color: #666; margin: 20px 0 0 0; line-height: 1.6;">
  Regards,<br>
  <strong style="color: #2C5270;">CrediScore Trust & Safety Team</strong>
</p>
<%- include('_footer') %>
