<%- include('_header') %>
<h1 style="font-size: 26px; font-weight: 600; color: #1a1a1a; margin: 0 0 25px 0; line-height: 1.3;">Your Password Has Been Changed</h1>

<p style="font-size: 16px; color: #666; margin: 0 0 25px 0; line-height: 1.6;">
  Dear <strong style="color: #2C5270;"><%= name %></strong>,
</p>

<p style="font-size: 15px; color: #333; line-height: 1.8; margin: 0 0 20px 0;">
  This is a confirmation that the password for your CrediScore account (<a href="mailto:<%= email %>" style="color: #2C5270; text-decoration: none;"><%= email %></a>) was successfully changed.
</p>

<!-- Success Box -->
<div style="background: linear-gradient(135deg, #e8f5e8 0%, #d4edda 100%); border-left: 4px solid #28a745; border-radius: 8px; padding: 18px 22px; margin: 25px 0;">
  <p style="font-size: 15px; font-weight: 600; color: #155724; margin: 0 0 6px 0;">✅ Password changed successfully</p>
  <p style="font-size: 13px; color: #1e4d2b; margin: 0;">
    Changed at: <strong><%= new Date().toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }) %></strong>
  </p>
</div>

<!-- Security Warning -->
<div style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%); border-left: 4px solid #f39c12; border-radius: 8px; padding: 18px 22px; margin: 25px 0;">
  <p style="font-size: 14px; font-weight: 700; color: #856404; margin: 0 0 10px 0;">⚠ Was this you?</p>
  <p style="font-size: 14px; color: #533f03; margin: 0 0 12px 0; line-height: 1.7;">
    If you made this change, no further action is required. However, if you did <strong>not</strong> change your password, your account may be compromised. Please act immediately:
  </p>
  <ul style="color: #533f03; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 18px;">
    <li>Use the "Forgot Password" option to regain access</li>
    <li>Contact our support team right away</li>
  </ul>
</div>

<div style="text-align: center; margin: 30px 0;">
  <a href="<%= appUrl %>/auth/forgot-password"
     style="display: inline-block; background: linear-gradient(135deg, #2C5270 0%, #3A6B8A 100%); color: #ffffff; text-decoration: none; padding: 13px 30px; border-radius: 8px; font-weight: 600; font-size: 15px; box-shadow: 0 4px 12px rgba(44, 82, 112, 0.3); margin-right: 10px;">
    Secure My Account →
  </a>
  <a href="mailto:support@crediscore.com"
     style="display: inline-block; background: #f8f9fa; color: #2C5270; text-decoration: none; padding: 13px 30px; border-radius: 8px; font-weight: 500; font-size: 15px; border: 1px solid #dee2e6;">
    Contact Support
  </a>
</div>

<p style="font-size: 15px; color: #666; margin: 25px 0 0 0; line-height: 1.6;">
  Stay safe,<br>
  <strong style="color: #2C5270;">The CrediScore Team</strong>
</p>
<%- include('_footer') %>
