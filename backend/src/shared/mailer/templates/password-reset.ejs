<%- include('_header') %>
<h1 style="font-size: 26px; font-weight: 600; color: #1a1a1a; margin: 0 0 25px 0; line-height: 1.3;">Password Reset Request</h1>

<p style="font-size: 16px; color: #666; margin: 0 0 25px 0; line-height: 1.6;">
  Dear <strong style="color: #2C5270;"><%= name %></strong>,
</p>

<p style="font-size: 15px; color: #333; line-height: 1.8; margin: 0 0 20px 0;">
  We received a request to reset the password for your CrediScore account. Click the button below to set a new password.
</p>

<!-- Action Box -->
<div style="background: #f8f9fa; border-radius: 12px; padding: 30px; margin: 30px 0; text-align: center;">
  <p style="font-size: 14px; color: #666; margin: 0 0 20px 0;">Your password reset link expires at:</p>
  <p style="font-size: 16px; font-weight: 700; color: #2C5270; margin: 0 0 25px 0;">
    <%= new Date(Date.now() + 3600000).toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }) %>
  </p>
  <a href="<%= resetUrl %>"
     style="display: inline-block; background: linear-gradient(135deg, #2C5270 0%, #3A6B8A 100%); color: #ffffff; text-decoration: none; padding: 14px 35px; border-radius: 8px; font-weight: 600; font-size: 16px; box-shadow: 0 4px 12px rgba(44, 82, 112, 0.3);">
    Reset My Password →
  </a>
</div>

<!-- Security Warning -->
<div style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%); border-left: 4px solid #f39c12; border-radius: 8px; padding: 18px 22px; margin: 25px 0;">
  <p style="font-size: 14px; font-weight: 700; color: #856404; margin: 0 0 8px 0;">⚠ Security Notice</p>
  <ul style="color: #533f03; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 18px;">
    <li>This link is valid for <strong>1 hour</strong> only.</li>
    <li>If you did not request a password reset, please ignore this email — your password will remain unchanged.</li>
    <li>Never share this link with anyone.</li>
  </ul>
</div>

<p style="font-size: 14px; color: #888; line-height: 1.7; margin: 25px 0 0 0;">
  If the button above doesn't work, copy and paste this link into your browser:<br>
  <a href="<%= resetUrl %>" style="color: #2C5270; word-break: break-all;"><%= resetUrl %></a>
</p>

<p style="font-size: 15px; color: #666; margin: 25px 0 0 0; line-height: 1.6;">
  Stay safe,<br>
  <strong style="color: #2C5270;">The CrediScore Team</strong>
</p>
<%- include('_footer') %>
