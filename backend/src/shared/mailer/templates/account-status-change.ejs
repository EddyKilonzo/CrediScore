<%- include('_header') %>
<h1 style="font-size: 26px; font-weight: 600; color: #1a1a1a; margin: 0 0 25px 0; line-height: 1.3;">Account Status Update</h1>

<p style="font-size: 16px; color: #666; margin: 0 0 25px 0; line-height: 1.6;">
  Dear <strong style="color: #2C5270;"><%= name %></strong>,
</p>

<p style="font-size: 15px; color: #333; line-height: 1.8; margin: 0 0 20px 0;">
  We wanted to inform you that your CrediScore account status has been updated.
</p>

<!-- Status Badge -->
<% if (status === 'activated') { %>
<div style="background: linear-gradient(135deg, #e8f5e8 0%, #d4edda 100%); border-left: 4px solid #28a745; border-radius: 8px; padding: 20px 25px; margin: 25px 0;">
  <p style="font-size: 16px; font-weight: 700; color: #155724; margin: 0 0 12px 0;">✅ Account Activated Successfully</p>
  <ul style="color: #1e4d2b; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 18px;">
    <li>You can now log in to your account</li>
    <li>Access your dashboard and profile</li>
    <li>Browse and review businesses</li>
    <li>Build your reputation score</li>
  </ul>
</div>
<% } else { %>
<div style="background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%); border-left: 4px solid #dc3545; border-radius: 8px; padding: 20px 25px; margin: 25px 0;">
  <p style="font-size: 16px; font-weight: 700; color: #721c24; margin: 0 0 12px 0;">⚠ Account Deactivated</p>
  <ul style="color: #721c24; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 18px;">
    <li>You cannot currently log in to your account</li>
    <li>Access to platform features is restricted</li>
    <li>You will not receive platform notifications during this period</li>
  </ul>
</div>
<% } %>

<% if (reason) { %>
<div style="background: #f8f9fa; border-left: 4px solid #2C5270; border-radius: 8px; padding: 18px 22px; margin: 25px 0;">
  <p style="font-size: 14px; font-weight: 700; color: #2C5270; margin: 0 0 8px 0;">Additional Information</p>
  <p style="color: #333; font-size: 14px; margin: 0; line-height: 1.7;"><%= reason %></p>
</div>
<% } %>

<p style="font-size: 15px; color: #333; line-height: 1.8; margin: 20px 0;">
  If you have any questions about this change or believe it was made in error, please contact our support team.
</p>

<div style="text-align: center; margin: 30px 0;">
  <a href="<%= appUrl %>/contact"
     style="display: inline-block; background: linear-gradient(135deg, #2C5270 0%, #3A6B8A 100%); color: #ffffff; text-decoration: none; padding: 13px 30px; border-radius: 8px; font-weight: 600; font-size: 15px; box-shadow: 0 4px 12px rgba(44, 82, 112, 0.3);">
    Contact Support →
  </a>
</div>

<p style="font-size: 15px; color: #666; margin: 25px 0 0 0; line-height: 1.6;">
  Best regards,<br>
  <strong style="color: #2C5270;">The CrediScore Team</strong>
</p>
<%- include('_footer') %>
